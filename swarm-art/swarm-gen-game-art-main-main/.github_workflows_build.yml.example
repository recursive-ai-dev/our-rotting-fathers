# GitHub Actions Workflow Example - Multi-Platform Build
#
# This file shows how to automate packaging for all platforms.
#
# Instructions:
#   1. Create .github/workflows/ directory (if it doesn't exist)
#   2. Copy this file to .github/workflows/build.yml
#   3. Push to GitHub
#   4. On each tag (git tag v2.0.0 && git push --tags), builds run automatically
#   5. Artifacts appear in GitHub Releases

name: Multi-Platform Build

on:
  push:
    tags:
      - 'v*'  # Run on version tags (v1.0.0, v2.0.0, etc.)
  workflow_dispatch:  # Allow manual trigger from GitHub UI

env:
  PYTHON_VERSION: '3.11'

jobs:
  build-windows:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install PyInstaller

      - name: Build executable
        run: |
          pyinstaller GameArtGenerator.spec --distpath ./dist

      - name: Upload to Release
        uses: softprops/action-gh-release@v1
        if: startsWith(github.ref, 'refs/tags/')
        with:
          files: dist/GameArtGenerator.exe
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  build-macos:
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install PyInstaller dmg

      - name: Build app bundle
        run: |
          pyinstaller GameArtGenerator.spec --distpath ./dist

      - name: Create DMG
        run: |
          hdiutil create -volname "GameArtGenerator" \
            -srcfolder dist/GameArtGenerator.app \
            -ov -format UDZO \
            dist/GameArtGenerator.dmg

      - name: Upload to Release
        uses: softprops/action-gh-release@v1
        if: startsWith(github.ref, 'refs/tags/')
        with:
          files: dist/GameArtGenerator.dmg
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  build-linux:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install PyInstaller

      - name: Build executable
        run: |
          pyinstaller GameArtGenerator.spec --distpath ./dist

      - name: Download linuxdeploy
        run: |
          wget https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage
          chmod +x linuxdeploy-x86_64.AppImage

      - name: Create AppImage
        run: |
          mkdir -p GameArtGenerator.AppDir/usr/bin
          cp dist/GameArtGenerator GameArtGenerator.AppDir/usr/bin/
          cp GameArtGenerator.desktop GameArtGenerator.AppDir/
          cp assets/GameArtGenerator.png GameArtGenerator.AppDir/
          ./linuxdeploy-x86_64.AppImage --appdir GameArtGenerator.AppDir --output appimage

      - name: Create DEB package
        run: |
          pip install fpm
          fpm -s dir -t deb \
            -n gamearartgenerator \
            -v ${GITHUB_REF#refs/tags/v} \
            -p ./dist/ \
            dist/GameArtGenerator=/usr/bin/ \
            GameArtGenerator.desktop=/usr/share/applications/ \
            assets/GameArtGenerator.png=/usr/share/icons/hicolor/512x512/apps/

      - name: Upload to Release
        uses: softprops/action-gh-release@v1
        if: startsWith(github.ref, 'refs/tags/')
        with:
          files: |
            GameArtGenerator-*.AppImage
            dist/gamearartgenerator_*.deb
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-cov

      - name: Run tests
        run: |
          pytest tests/ -v --tb=short

      - name: Generate coverage
        run: |
          pytest tests/ --cov=app --cov=generator --cov=export --cov-report=term-missing
